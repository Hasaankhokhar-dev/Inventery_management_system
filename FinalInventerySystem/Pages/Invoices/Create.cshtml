@* @page
@model FinalInventerySystem.Pages.Invoices.CreateModel
@{
    ViewData["Title"] = "Create Invoice";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-3">
        <!-- Header -->
        <div class="card-header text-white py-3"
             style="background: linear-gradient(90deg, #0062E6, #33AEFF);">
            <h4 class="mb-0">
                📝 Create New Invoice
            </h4>
        </div>

        <!-- Body -->
        <div class="card-body">
            <form method="post">
                @Html.AntiForgeryToken()

                <!-- Customer Info -->
                <div class="row mb-4">
                    <div class="col-md-4">
                        <label asp-for="Invoice.CustomerName" class="form-label fw-bold">Customer Name</label>
                        <input asp-for="Invoice.CustomerName" class="form-control" placeholder="Enter customer name" required />
                        <span asp-validation-for="Invoice.CustomerName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Invoice.Phone" class="form-label fw-bold">Phone</label>
                        <input asp-for="Invoice.Phone" class="form-control" placeholder="e.g. 0300-1234567" />
                        <span asp-validation-for="Invoice.Phone" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Invoice.Address" class="form-label fw-bold">Address</label>
                        <input asp-for="Invoice.Address" class="form-control" placeholder="Customer address" />
                        <span asp-validation-for="Invoice.Address" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Product Search -->
                <div class="mb-4">
                    <label class="form-label fw-bold">🔎 Search Product</label>
                    <input type="text" id="productSearch" class="form-control" placeholder="Type product name..." autocomplete="off" />
                    <ul id="productResults" class="list-group position-absolute w-50"></ul>
                </div>

                <!-- Invoice Items -->
                <h5 class="text-primary fw-bold mb-3">🛒 Invoice Items</h5>
                <div class="table-responsive">
                    <table id="invoiceItems" class="table table-bordered table-striped shadow-sm">
                        <thead class="table-primary text-center align-middle">
                            <tr>
                                <th style="width:25%;">Product</th>
                                <th style="width:15%;">Available Stock</th>
                                <th style="width:15%;">Price</th>
                                <th style="width:15%;">Quantity</th>
                                <th style="width:15%;">Subtotal</th>
                                <th style="width:15%;">Action</th>
                            </tr>
                        </thead>
                        <tbody class="align-middle">
                            <!-- Items will be added dynamically -->
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="4" class="text-end fw-bold">💵 Total:</td>
                                <td class="text-end fw-bold text-success" id="grandTotal">Rs. 0</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <!-- Actions -->
                <div class="mt-4 d-flex justify-content-between">
                    <a asp-page="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-success px-4">
                        <i class="bi bi-save"></i> Save Invoice
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // ✅ Search products dynamically
        $("#productSearch").on("keyup", function () {
            let query = $(this).val();
            if (query.length < 1) {
                $("#productResults").empty();
                return;
            }

            $.getJSON("/Invoices/SearchProducts", { query: query }, function (results) {
                let list = "";
                results.forEach(p => {
                    list += `<li class="list-group-item list-group-item-action"
                                data-id="${p.id}" data-name="${p.name}"
                                data-price="${p.basePrice}" data-stock="${p.quantity}">
                                ${p.name} (Stock: ${p.quantity}, Price: Rs. ${p.basePrice})
                             </li>`;
                });
                $("#productResults").html(list);
            });
        });

        // ✅ Add selected product to invoice items
        $(document).on("click", "#productResults li", function () {
            let id = $(this).data("id");
            let name = $(this).data("name");
            let price = parseFloat($(this).data("price"));
            let stock = $(this).data("stock");

            let rowCount = $("#invoiceItems tbody tr").length;

            let row = `
                <tr class="align-middle text-center">
                    <td class="text-start">
                        ${name}
                        <input type="hidden" name="SelectedItems[${rowCount}].InventoryId" value="${id}" />
                    </td>
                    <td>${stock}</td>
                    <td class="text-end">Rs. ${price.toLocaleString()}</td>
                    <td>
                        <input type="number" name="SelectedItems[${rowCount}].Quantity"
                               value="1" min="1" max="${stock}"
                               class="form-control form-control-sm qty text-center mx-auto"
                               style="max-width:80px;" />
                    </td>
                    <td class="subtotal text-end fw-bold">Rs. ${price.toLocaleString()}</td>
                    <td>
                        <button type="button" class="btn btn-sm btn-danger removeItem">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                </tr>
            `;
            $("#invoiceItems tbody").append(row);
            $("#productResults").empty();
            $("#productSearch").val("");
            recalcTotals();
        });

        // ✅ Remove item
        $(document).on("click", ".removeItem", function () {
            $(this).closest("tr").remove();
            recalcTotals();
        });

        // ✅ Recalculate totals
        $(document).on("input", ".qty", recalcTotals);

        function recalcTotals() {
            let total = 0;
            $("#invoiceItems tbody tr").each(function () {
                let qty = parseFloat($(this).find(".qty").val()) || 0;
                let price = parseFloat($(this).find("td:nth-child(3)").text().replace("Rs.", "").replace(",", "")) || 0;
                let subtotal = qty * price;
                $(this).find(".subtotal").text("Rs. " + subtotal.toLocaleString());
                total += subtotal;
            });
            $("#grandTotal").text("Rs. " + total.toLocaleString());
        }
    </script>
}      ----------working ---------- *@





