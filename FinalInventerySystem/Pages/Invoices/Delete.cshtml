@page "{id:int}"
@model FinalInventerySystem.Pages.Invoices.DeleteModel
@{
    ViewData["Title"] = "Delete Invoice";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-danger text-white d-flex align-items-center">
                    <i class="bi bi-exclamation-triangle-fill fs-4 me-2"></i>
                    <h4 class="mb-0">Delete Invoice</h4>
                </div>
                <div class="card-body text-center">
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-circle me-2"></i>
                        <strong>Warning:</strong> This action cannot be undone!
                    </div>

                    <p class="fs-5">Are you sure you want to delete this invoice?</p>
                    <div class="mt-3 mb-4">
                        <p><strong>🧑 Customer:</strong> @Model.Invoice?.CustomerName</p>
                        <p><strong>💵 Total:</strong> @Model.Invoice?.TotalAmount.ToString("N2")</p>
                    </div>

                    <form method="post" class="d-flex justify-content-center gap-3">
                        <button type="submit" class="btn btn-lg btn-danger shadow-sm px-4">
                            <i class="bi bi-trash-fill me-2"></i> Delete
                        </button>
                        <a asp-page="Index" class="btn btn-lg btn-secondary shadow-sm px-4">
                            <i class="bi bi-x-circle me-2"></i> Cancel
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Bootstrap icons for warning/delete/cancel -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
}
