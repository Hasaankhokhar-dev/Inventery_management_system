
@model FinalInventerySystem.Helpers.PaginatedList<FinalInventerySystem.Models.Inventory>

<div class="container mt-4">
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-header text-white"
             style="background: linear-gradient(90deg, #007bff, #0056b3);">
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle text-center">
                    <thead class="table-primary">
                        <tr>
                            <th style="width: 15%;">Code</th>
                            <th style="width: 30%;">Name</th>
                            <th style="width: 20%;">Base Price</th>
                            <th style="width: 15%;">Stock</th>
                            <th style="width: 20%;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold text-center">@item.Code</td>
                                <td class="fw-semibold text-center">@item.Name</td>
                                <td class="text-center">Rs. @item.BasePrice.ToString("N0")</td>
                                <td class="fw-bold text-center">@item.Quantity</td>
                                <td class="text-center">
                                    <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-2">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <a asp-page="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- ✅ UPDATED PAGINATION - Advanced Smart Paging -->
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center mt-4">
                    <!-- Previous Button -->
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link" href="#" data-page="@(Model.PageIndex - 1)" aria-label="Previous">
                            <span aria-hidden="true">&laquo;</span>
                        </a>
                    </li>

                    <!-- Smart Page Numbers -->
                    @foreach (var pg in Model.GetSmartPageNumbers())
                    {
                        if (pg.IsEllipsis)
                        {
                            <li class="page-item disabled">
                                <span class="page-link">...</span>
                            </li>
                        }
                        else
                        {
                            <li class="page-item @(pg.Number == Model.PageIndex ? "active" : "")">
                                <a class="page-link" href="#" data-page="@pg.Number">
                                    @pg.Number
                                </a>
                            </li>
                        }
                    }

                    <!-- Next Button -->
                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link" href="#" data-page="@(Model.PageIndex + 1)" aria-label="Next">
                            <span aria-hidden="true">&raquo;</span>
                        </a>
                    </li>
                </ul>

                <!-- Page Info -->
                <div class="text-center text-muted small mt-2">
                    Page @Model.PageIndex of @Model.TotalPages • Total @Model.TotalCount items
                </div>
            </nav>
        </div>
    </div>
</div>

<style>
    .table td, .table th {
        vertical-align: middle;
        text-align: center !important;
    }

    .pagination .page-link {
        border-radius: 8px;
        margin: 0 3px;
    }

    .pagination .active .page-link {
        background-color: #007bff;
        border-color: #007bff;
        color: #fff;
    }
</style>