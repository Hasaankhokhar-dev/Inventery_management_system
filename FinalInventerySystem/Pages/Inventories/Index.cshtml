@page
@model FinalInventerySystem.Pages.Inventories.IndexModel
@{
    ViewData["Title"] = "Inventory List";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">📦 Inventory Management</h4>

            <!-- ✅ Search bar -->
            <div class="input-group w-25">
                <span class="input-group-text bg-light"><i class="bi bi-search"></i></span>
                <input type="text" id="searchInput" class="form-control" placeholder="Search items..." autocomplete="off">
            </div>
        </div>

        <div class="card-body">
            <div class="d-flex justify-content-end mb-3">
                <!-- ✅ CURRENT PAGE ADD KARO - AJAX KE LIYE UPDATE -->
                <a asp-page="Create" id="createButton" asp-route-returnPage="@Model.InventoryList.PageIndex" class="btn btn-success">
                    <i class="bi bi-plus-circle"></i> Add New Item
                </a>
            </div>

            <!-- ✅ Table container (will be updated via AJAX) -->
            <div id="inventoryTableContainer">
                @await Html.PartialAsync("_InventoryTable", Model.InventoryList)
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        // ✅ Store current page globally
        let currentPageIndex = @Model.InventoryList.PageIndex;

        // ✅ Function to load data via AJAX
        function loadInventory(searchQuery, pageIndex) {
            currentPageIndex = pageIndex || currentPageIndex;

            $.get("/Inventories/Index", { searchString: searchQuery, pageIndex: pageIndex }, function (data) {
                // Extract only the table portion from returned HTML
                let tableHtml = $(data).find("#inventoryTableContainer").html();
                $("#inventoryTableContainer").html(tableHtml);

                // ✅ UPDATE CREATE BUTTON LINK WITH CURRENT PAGE
                $('#createButton').attr('href', '/Inventories/Create?returnPage=' + currentPageIndex);
            });
        }

        // ✅ Live search (instant filter, no reload)
        $("#searchInput").on("keyup", function () {
            let query = $(this).val();
            loadInventory(query, 1); // reset to first page on new search
        });

        // ✅ Handle pagination clicks dynamically
        $(document).on("click", ".pagination a", function (e) {
            e.preventDefault();
            let pageIndex = $(this).data("page");
            let query = $("#searchInput").val();
            loadInventory(query, pageIndex);
        });
    </script>
}