@page
@model FinalInventerySystem.Pages.Customer.IndexModel
@{
    ViewData["Title"] = "Electricians";
}

<div class="container-fluid">
    <!-- ✅ Top Line Display -->
    <div class="row mb-3">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-body py-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 text-primary">
                            <i class="bi bi-lightning-charge-fill"></i> Electricians Management
                        </h5>
                        <!-- Search Bar -->
                        <div class="d-flex align-items-center">
                            <input type="text" id="searchInput" class="form-control me-2" placeholder="Search electricians..." style="width: 250px;">
                            <button class="btn btn-outline-primary" onclick="searchElectricians()">
                                <i class="bi bi-search"></i> Search
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ✅ Add Electrician Button & Form -->
    <div class="row mb-4">
        <div class="col-12">
            <button class="btn btn-success mb-3" type="button" data-bs-toggle="collapse" data-bs-target="#electricianForm">
                <i class="bi bi-person-plus"></i> Add New Electrician
            </button>

            <!-- ✅ Electrician Form (Collapsible) -->
            <div class="collapse mb-3" id="electricianForm">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h6 class="mb-0"><i class="bi bi-person-badge"></i> Electrician Details</h6>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="NewCustomer.Name" class="form-label">Electrician Name *</label>
                                        <input asp-for="NewCustomer.Name" class="form-control" required>
                                        <span asp-validation-for="NewCustomer.Name" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="NewCustomer.Phone" class="form-label">Phone Number *</label>
                                        <input asp-for="NewCustomer.Phone" class="form-control" required maxlength="11" minlength="11">
                                        <span asp-validation-for="NewCustomer.Phone" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="NewCustomer.Address" class="form-label">Address</label>
                                        <input asp-for="NewCustomer.Address" class="form-control">
                                        <span asp-validation-for="NewCustomer.Address" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-3">
                                <button type="submit" class="btn btn-success">
                                    <i class="bi bi-check-circle"></i> Save Electrician
                                </button>
                                <button type="button" class="btn btn-secondary" data-bs-toggle="collapse" data-bs-target="#electricianForm">
                                    <i class="bi bi-x-circle"></i> Cancel
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ✅ Electricians Table -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-list-ul"></i> Electricians List</h6>
                </div>
                <div class="card-body">
                    @if (Model.Customers.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>ID</th>
                                        <th>Electrician Name</th>
                                        <th>Phone</th>
                                        <th>Address</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var electrician in Model.Customers)
                                    {
                                        <tr>
                                            <td>@electrician.Id</td>
                                            <td>@electrician.Name</td>
                                            <td>@electrician.Phone</td>
                                            <td>@electrician.Address</td>
                                            <td>
                                                <!-- Delete Button Only -->
                                                <form method="post" asp-page-handler="Delete" style="display: inline;"
                                                      onsubmit="return confirm('Are you sure you want to delete this electrician?');">
                                                    <input type="hidden" name="id" value="@electrician.Id" />
                                                    <button type="submit" class="btn btn-sm btn-danger">
                                                        <i class="bi bi-trash"></i> Delete
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info text-center">
                            <i class="bi bi-info-circle"></i> No electricians found. Add your first electrician above.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Auto-hide success message after 3 seconds
        setTimeout(function() {
            const alert = document.querySelector('.alert-success');
            if (alert) {
                alert.style.display = 'none';
            }
        }, 3000);

        // Professional Real-time Search functionality - Starts from first character
        function initializeSearch() {
            const searchInput = document.getElementById('searchInput');

            // Real-time search as user types - starts from first character
            searchInput.addEventListener('input', function() {
                const searchTerm = this.value.toLowerCase().trim();
                performSearch(searchTerm);
            });

            // Clear search with Escape key
            searchInput.addEventListener('keyup', function(e) {
                if (e.key === 'Escape') {
                    this.value = '';
                    performSearch('');
                }
            });
        }

        function performSearch(searchTerm) {
            const rows = document.querySelectorAll('tbody tr');
            let visibleCount = 0;

            rows.forEach(row => {
                const name = row.cells[1].textContent.toLowerCase();
                const phone = row.cells[2].textContent.toLowerCase();
                const address = row.cells[3].textContent.toLowerCase();

                // Check if any field starts with the search term (even for single character)
                const matches = name.startsWith(searchTerm) ||
                              phone.startsWith(searchTerm) ||
                              address.startsWith(searchTerm);

                if (matches || searchTerm === '') {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });

            // Update results count (optional)
            updateResultsCount(visibleCount);
        }

        function updateResultsCount(count) {
            // You can add a results counter if needed
            const totalCount = document.querySelectorAll('tbody tr').length;
            if (count === totalCount) {
                // All results showing
            } else {
                // Some results filtered
            }
        }

        // Initialize search when page loads
        document.addEventListener('DOMContentLoaded', function() {
            initializeSearch();
        });
    </script>
}



