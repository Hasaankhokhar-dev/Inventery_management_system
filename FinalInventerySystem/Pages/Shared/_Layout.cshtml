@* 

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AL-Madina Electric & Solar House</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FinalInventerySystem.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" />
    <style>
        /* Navbar styling */
        .navbar-custom {
            background: linear-gradient(90deg, #007bff, #6610f2);
        }

            .navbar-custom .nav-link {
                color: white !important;
                font-weight: 600;
                margin-left: 15px;
                transition: 0.3s ease;
            }

                .navbar-custom .nav-link:hover {
                    color: #ffd700 !important; /* golden yellow on hover */
                    text-decoration: underline;
                }

        .navbar-brand {
            font-size: 1.3rem;
            letter-spacing: 0.5px;
        }

        /* Right aligned navigation */
        .navbar-nav-right {
            margin-left: auto !important;
        }

        .nav-item-right {
            margin-left: 15px;
        }
    </style>
</head>
<body>
    <header>
        <!-- ✅ Branded Navbar -->
        <nav class="navbar navbar-expand-sm navbar-dark navbar-custom shadow mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold text-white" asp-area="" asp-page="/Inventories/Index">
                    🏪 AL-Madina Electric & Solar House
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <!-- Navigation Links - RIGHT ALIGNED -->
                    <ul class="navbar-nav navbar-nav-right">
                        <!-- ✅ Inventory is Home -->
                        <li class="nav-item nav-item-right">
                            <a class="nav-link" asp-page="/Inventories/Index">
                                <i class="bi bi-house-door-fill"></i> Home
                            </a>
                        </li>
                        <li class="nav-item nav-item-right">
                            <a class="nav-link" asp-page="/Invoices/Index">
                                <i class="bi bi-receipt"></i> Invoices
                            </a>
                        </li>
                        <li class="nav-item nav-item-right">
                            <a class="nav-link" asp-page="/Customer/Index">
                                <i class="bi bi-lightning-charge-fill"></i> Electricians
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html> *@





