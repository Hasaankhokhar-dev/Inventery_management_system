<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AL-Madina Electric & Solar House</title>

    <!-- ✅ Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">

    <!-- ✅ Local CSS files -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        /* Navbar styling */
        .navbar-custom {
            background: linear-gradient(90deg, #007bff, #6610f2);
        }

            .navbar-custom .nav-link {
                color: white !important;
                font-weight: 600;
                margin-left: 15px;
                transition: 0.3s ease;
            }

                .navbar-custom .nav-link:hover {
                    color: #ffd700 !important;
                    text-decoration: underline;
                }

                .navbar-custom .nav-link.active {
                    color: #ffd700 !important;
                    background: rgba(255, 255, 255, 0.1);
                    border-radius: 5px;
                    padding: 5px 15px;
                    font-weight: bold;
                }

        .navbar-brand {
            font-size: 1.3rem;
            letter-spacing: 0.5px;
        }

        .navbar-nav-right {
            margin-left: auto !important;
        }

        .nav-item-right {
            margin-left: 15px;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark navbar-custom shadow mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold text-white" asp-area="" asp-page="/Inventories/Index">
                    🏪 AL-Madina Electric & Solar House
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav navbar-nav-right">
                        <li class="nav-item nav-item-right">
                            <a class="nav-link" asp-page="/Inventories/Index" id="nav-home">
                                <i class="bi bi-house-door-fill"></i> Home
                            </a>
                        </li>
                        <li class="nav-item nav-item-right">
                            <a class="nav-link" asp-page="/Invoices/Index" id="nav-invoices">
                                <i class="bi bi-receipt"></i> Invoices
                            </a>
                        </li>
                        <li class="nav-item nav-item-right">
                            <a class="nav-link" asp-page="/Customer/Index" id="nav-electricians">
                                <i class="bi bi-lightning-charge-fill"></i> Electricians
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- ✅ Bootstrap JS CDN -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // ✅ Active Navigation Highlight
        $(document).ready(function () {
            var currentUrl = window.location.href;
            $('.navbar-custom .nav-link').removeClass('active');

            $('.navbar-custom .nav-link').each(function () {
                var linkUrl = $(this).attr('href');
                if (currentUrl.includes(linkUrl) && linkUrl !== '/') {
                    $(this).addClass('active');
                }
            });

            if (currentUrl.includes('/Inventories/Index') ||
                currentUrl.endsWith('/') ||
                currentUrl.includes('/Inventories/Create') ||
                currentUrl.includes('/Inventories/Edit') ||
                currentUrl.includes('/Inventories/Delete')) {
                $('#nav-home').addClass('active');
            }

            if (currentUrl.includes('/Invoices/') && !currentUrl.includes('/Customer/')) {
                $('#nav-invoices').addClass('active');
            }

            if (currentUrl.includes('/Customer/')) {
                $('#nav-electricians').addClass('active');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>